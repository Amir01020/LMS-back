# copy .env.docker.example .env.docker

# Фронт уже на https://bit-system.uz — backend принимает запросы только оттуда
CORS_ORIGIN=https://bit-system.uz
API_BASE_URL=https://api.bit-system.uz

# PostgreSQL (контейнер db в docker-compose)
DB_NAME=school_lms
DB_USER=postgres
DB_PASSWORD=change_me_in_production

# JWT — смените на сервере
JWT_ACCESS_SECRET=change_me_access_secret_long_random
JWT_REFRESH_SECRET=change_me_refresh_secret_long_random
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Super admin при первом запуске
ADMIN_EMAIL=admin@school.local
ADMIN_PASSWORD=1111
SUPER_ADMIN_EMAIL=superadmin@school.local
SUPER_ADMIN_PASSWORD=superadmin123

# true — создать super admin при старте; false — только если БД уже заполнена
AUTO_SEED=true
SEED_DEMO_DATA=false

# Порт API на хосте (nginx проксирует api.bit-system.uz -> 127.0.0.1:3000)
API_PORT=3000
DB_PORT=5432

MAX_FILE_SIZE=5242880
