PORT=3000
NODE_ENV=development

# Database (postgres по ТЗ, mysql тоже поддерживается)
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=school_lms
DB_USER=postgres
DB_PASSWORD=your_password
DB_SSL=false
DB_FORCE_SYNC=false

# JWT
JWT_ACCESS_SECRET=your_access_secret
JWT_REFRESH_SECRET=your_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CORS_ORIGIN=http://localhost:5173

# Admin seed
ADMIN_EMAIL=admin@school.local
ADMIN_PASSWORD=1111

# Super Admin seed
SUPER_ADMIN_EMAIL=superadmin@school.local
SUPER_ADMIN_PASSWORD=superadmin123

# Super admin (глобальный управляющий)
SUPER_ADMIN_EMAIL=superadmin@school.local
SUPER_ADMIN_PASSWORD=superadmin123

# Alter existing tables on startup (adds new columns/enums without dropping data)
DB_ALTER_SYNC=true
